{
	"servers": {
		"mui-mcp": {
			"type": "stdio",
			"sandboxEnabled": false,
			"command": "npx",
			"cwd": "${input:cwd}",
			/* "args": [
				"@mui/mcp@0.1.0"
			], */
			"args": ["-y", "@mui/mcp@latest"],
			"env": {},
			"dev": {
				"watch": [],
				"debug": {
					"type": "${input:debugType}"
				}
			}
		}
	},
	"inputs": [
		{
			"id": "cwd",
			"type": "promptString",
			"description": "Current Working Directory"
		},
		{
			"id": "debugType",
			"type": "promptString",
			"description": "Debug Type"
		}
	]
}